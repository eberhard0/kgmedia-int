# Self-hosted deployment env template
# Copy to /opt/kgmedia/app/.env.local on the server, fill in real values,
# chmod 0600. See SELFHOST.md Phase 3a.

# ───── Database (replaces all SUPABASE_* vars) ─────────────────────────
# Format: postgres://user:password@host:port/dbname?sslmode=...
# For localhost on the same box, omit sslmode entirely.
DATABASE_URL=postgres://kgmedia_app:REPLACE_ME@localhost:5432/kgmedia_int

# ───── AI providers ─────────────────────────────────────────────────────
# Claude Haiku 4.5 — entity extraction
ANTHROPIC_API_KEY=sk-ant-...
# Voyage AI voyage-3-lite — semantic clustering
VOYAGE_API_KEY=pa-...

# ───── Apify ────────────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_...

# ───── Cron auth ────────────────────────────────────────────────────────
# systemd timers send `Authorization: Bearer ${CRON_SECRET}` to the locked
# scan endpoints. Generate with: openssl rand -hex 32
CRON_SECRET=REPLACE_ME

# ───── Optional offsite backup ──────────────────────────────────────────
# If set, scripts/backup.sh will rclone the nightly dump here.
# RCLONE_REMOTE=s3:my-bucket/kgmedia/

# ───── App ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
NEXT_TELEMETRY_DISABLED=1
